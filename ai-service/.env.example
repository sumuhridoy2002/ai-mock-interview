# Mock Interview Pro — AI Service
AI_USE_MOCK=false
AI_SERVICE_SECRET=

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Speech-to-text (Whisper)
WHISPER_MODEL=small

# Vision / behavior analysis
# Default: lightweight HF emotion classifier (GPU used when torch.cuda is available)
EMOTION_MODEL=dima806/facial_emotions_image_detection
# Alternatives (image-classification compatible):
# EMOTION_MODEL=trpakov/vit-face-expression
# EMOTION_MODEL=HardlyHumans/Facial-expression-detection

EMOTION_BATCH_SIZE=8
MAX_EMOTION_FRAMES=12
SNAPSHOT_INTERVAL_SEC=10

# Optional: path to ffmpeg binary (librosa prosody extraction)
# FFMPEG_PATH=
